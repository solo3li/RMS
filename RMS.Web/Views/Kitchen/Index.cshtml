@using RMS.Web.Models
@model IEnumerable<RMS.Web.Models.Order>
@{
    ViewData["Title"] = "Kitchen Dashboard";
}

<div class="kitchen-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-dark text-white rounded">
        <h1 class="mb-0 fw-bold"><i class="fas fa-fire-alt me-2"></i>KITCHEN DISPLAY</h1>
        <div class="text-end">
            <h2 id="clock" class="mb-0 fw-bold">00:00:00</h2>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var order in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-lg @(order.Status == OrderStatus.Preparing ? "border-warning border-5" : "border-info border-5")">
                    <div class="card-header @(order.Status == OrderStatus.Preparing ? "bg-warning text-dark" : "bg-info text-white") p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <h2 class="mb-0 fw-bold">#@order.ID</h2>
                            <div>
                                <a href="@Url.Action("Receipt", "Orders", new { id = order.ID, print = true })" target="_blank" class="btn btn-light btn-sm me-2">
                                    <i class="fas fa-print"></i>
                                </a>
                                <span class="badge bg-white text-dark fs-4">@order.OrderType</span>
                            </div>
                        </div>
                        <div class="mt-2 fs-5 fw-bold">
                            <i class="far fa-clock me-1"></i> @order.CreatedAt.ToString("HH:mm") (@((int)(DateTime.UtcNow - order.CreatedAt).TotalMinutes) min ago)
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <div class="list-group list-group-flush border rounded mb-3">
                            @foreach (var item in order.OrderItems)
                            {
                                <div class="list-group-item p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h3 class="mb-0 fw-bold">@item.MenuItem.Name</h3>
                                        <span class="badge bg-primary rounded-pill fs-3">x @item.Quantity</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.Notes))
                                    {
                                        <div class="bg-danger-subtle p-2 rounded mt-2 border border-danger">
                                            <strong class="text-danger fs-5"><i class="fas fa-exclamation-triangle me-1"></i> @item.Notes</strong>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(order.Notes))
                        {
                            <div class="bg-light p-3 border rounded border-3">
                                <h4 class="fw-bold text-uppercase border-bottom pb-2 mb-2">Order Notes</h4>
                                <p class="fs-4 text-danger mb-0 fw-bold">@order.Notes</p>
                            </div>
                        }
                    </div>
                    <div class="card-footer p-0 border-0 bg-transparent">
                        @if (order.Status == OrderStatus.Confirmed)
                        {
                            <form asp-action="StartPreparing" method="post" class="m-0">
                                <input type="hidden" name="id" value="@order.ID" />
                                <button type="submit" class="btn btn-warning btn-lg w-100 py-5 fs-1 fw-bold rounded-0">START PREPARING</button>
                            </form>
                        }
                        else if (order.Status == OrderStatus.Preparing)
                        {
                            <form asp-action="MarkReady" method="post" class="m-0">
                                <input type="hidden" name="id" value="@order.ID" />
                                <button type="submit" class="btn btn-success btn-lg w-100 py-5 fs-1 fw-bold rounded-0">MARK READY</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        // Update clock
        function updateClock() {
            const now = new Date();
            document.getElementById('clock').innerText = now.toLocaleTimeString();
        }
        setInterval(updateClock, 1000);
        updateClock();

        // SignalR Connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/orderHub")
            .build();

        connection.on("NewOrderReceived", function (orderId) {
            console.log("New order received: " + orderId);
            location.reload();
        });

        connection.on("OrderStatusUpdated", function (orderId, status) {
            // Reload if status changed
            location.reload();
        });

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}

<style>
    .kitchen-dashboard {
        background-color: #212529;
        min-height: calc(100vh - 100px);
        padding: 20px;
        margin: -20px;
    }
    .card {
        background-color: #f8f9fa;
        min-height: 400px;
    }
    .bg-danger-subtle {
        background-color: #f8d7da;
    }
</style>
