@model RMS.Web.Models.AuditLog

@{
    ViewData["Title"] = "Audit Log Details";
}

<h1>Audit Log Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Timestamp</dt>
        <dd class="col-sm-10">@Model.Timestamp.ToLocalTime()</dd>

        <dt class="col-sm-2">User</dt>
        <dd class="col-sm-10">@(Model.User?.UserName ?? Model.UserId)</dd>

        <dt class="col-sm-2">Action</dt>
        <dd class="col-sm-10">@Model.Action</dd>

        <dt class="col-sm-2">Entity Type</dt>
        <dd class="col-sm-10">@Model.EntityType</dd>

        <dt class="col-sm-2">Entity ID</dt>
        <dd class="col-sm-10">@Model.EntityId</dd>

        <dt class="col-sm-2">Before Value</dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.BeforeValue))
            {
                <pre>@Model.BeforeValue</pre>
            }
            else
            {
                <span>None</span>
            }
        </dd>

        <dt class="col-sm-2">After Value</dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.AfterValue))
            {
                <pre>@Model.AfterValue</pre>
            }
            else
            {
                <span>None</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
