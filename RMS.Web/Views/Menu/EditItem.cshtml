@model RMS.Web.Models.MenuItem

@{
    ViewData["Title"] = "Edit Menu Item";
}

<div class="mb-4">
    <h1 class="h3 mb-0 text-gray-800">Edit Menu Item: @Model.Name</h1>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Item Details</h6>
            </div>
            <div class="card-body">
                <form asp-action="EditItem" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="ID" />
                    <input type="hidden" asp-for="ImageUrl" />
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label font-weight-bold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label font-weight-bold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label font-weight-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CategoryId" class="form-label font-weight-bold">Category</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Item Image</label>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-2">
                                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-thumbnail" style="max-height: 150px;" />
                            </div>
                        }
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        <small class="text-muted">Upload a new professional photo to replace the current one.</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="AvailableFrom" class="form-label font-weight-bold">Available From</label>
                            <input asp-for="AvailableFrom" class="form-control" type="datetime-local" />
                            <span asp-validation-for="AvailableFrom" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="AvailableTo" class="form-label font-weight-bold">Available To</label>
                            <input asp-for="AvailableTo" class="form-control" type="datetime-local" />
                            <span asp-validation-for="AvailableTo" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsAvailableGlobal">
                            <label class="form-check-label font-weight-bold" asp-for="IsAvailableGlobal">Available Globally</label>
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-between">
                        <div>
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Back to List</a>
                        </div>
                        <div>
                            <a asp-action="ManageOptions" asp-route-id="@Model.ID" class="btn btn-info">
                                <i class="bi bi-gear-fill me-1"></i> Manage Options (Extras/Variants)
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
