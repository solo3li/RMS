@model IEnumerable<RMS.Web.Models.MenuItem>

@{
    ViewData["Title"] = "Menu Management";
    var categories = ViewBag.Categories as IEnumerable<RMS.Web.Models.Category>;
    int? selectedCategoryId = ViewBag.SelectedCategoryId;
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Menu Management</h1>
    <div>
        <a asp-action="CreateCategory" class="btn btn-sm btn-outline-primary shadow-sm mr-2">
            <i class="fas fa-folder-plus fa-sm"></i> Add Category
        </a>
        <a asp-action="CreateItem" class="btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Add Menu Item
        </a>
    </div>
</div>

<!-- Category Filter -->
<div class="mb-4">
    <div class="btn-group flex-wrap" role="group">
        <a asp-action="Index" class="btn @(selectedCategoryId == null ? "btn-primary" : "btn-outline-primary")">All</a>
        @if (categories != null)
        {
            @foreach (var cat in categories)
            {
                <a asp-action="Index" asp-route-categoryId="@cat.ID" 
                   class="btn @(selectedCategoryId == cat.ID ? "btn-primary" : "btn-outline-primary")">
                    @cat.Name
                </a>
            }
        }
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Menu Items</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="width: 60px;">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" class="img-thumbnail" style="max-width: 50px;" />
                                }
                                else
                                {
                                    <div class="bg-light text-center rounded" style="width: 50px; height: 50px; line-height: 50px;">
                                        <i class="fas fa-utensils text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div><strong>@item.Name</strong></div>
                                <small class="text-muted">@item.Description</small>
                            </td>
                            <td>@item.Category.Name</td>
                            <td>@item.Price.ToString("C")</td>
                            <td>
                                @if (item.IsAvailableGlobal)
                                {
                                    <span class="badge bg-soft-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-soft-warning">Unavailable</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="EditItem" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
