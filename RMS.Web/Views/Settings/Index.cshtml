@model IEnumerable<RMS.Web.Models.SystemSetting>

@{
    ViewData["Title"] = "System Settings";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">System Settings</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Configuration Values</h6>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div class="table-responsive">
                            <table class="table" width="100%" cellspacing="0">
                                <thead>
                                    <tr>
                                        <th>Setting</th>
                                        <th>Value</th>
                                        <th>Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int index = 0;
                                    }
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td style="width: 30%;">
                                                <label class="font-weight-bold">@item.Key</label>
                                                <input type="hidden" name="settings[@index].Key" value="@item.Key" />
                                            </td>
                                            <td>
                                                <input type="text" name="settings[@index].Value" value="@item.Value" class="form-control" />
                                            </td>
                                            <td class="text-muted small">
                                                @item.Description
                                            </td>
                                        </tr>
                                        index++;
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save All Settings
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info text-uppercase">Help</h6>
                </div>
                <div class="card-body">
                    <p>Update global system configurations here. These settings affect calculations, labels, and display formats across the entire platform.</p>
                    <ul>
                        <li><strong>StoreName:</strong> Displayed in the layout and receipt.</li>
                        <li><strong>CurrencySymbol:</strong> Used for all price displays.</li>
                        <li><strong>TaxRate:</strong> Percentage added to orders (0 to 100).</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
