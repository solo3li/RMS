@model RMS.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">Operational Dashboard</h1>
    <div class="text-muted small">
        <i class="fas fa-calendar-alt me-1"></i> @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
    </div>
</div>

<!-- KPI Cards -->
<div class="row">
    <!-- Today's Orders -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start border-primary border-4 shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Orders (Today)</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalOrdersToday</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-shopping-cart fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Today's Revenue -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start border-success border-4 shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Revenue (Today)</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalRevenueToday.ToString("C")</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Orders -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start border-info border-4 shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Pending Orders</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.PendingOrders</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-clock fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Branches -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start border-warning border-4 shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Active Branches</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.ActiveBranches</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-store fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Recent Activity -->
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Recent Orders</h6>
                <a asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Branch</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td><strong>#@order.ID</strong></td>
                                    <td>@order.Customer.Name</td>
                                    <td>@order.Branch.Name</td>
                                    <td>@order.TotalPrice.ToString("C")</td>
                                    <td>
                                        <span class="badge bg-soft-info text-info">@order.Status</span>
                                    </td>
                                    <td>
                                        <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.ID" class="btn btn-sm btn-light">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.RecentOrders.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">No recent orders.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-lg-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-controller="CallCenter" asp-action="Index" class="btn btn-primary btn-lg text-start mb-2">
                        <i class="fas fa-phone-alt me-2"></i> New Call Center Order
                    </a>
                    <a asp-controller="Menu" asp-action="Index" class="btn btn-light text-start border mb-2">
                        <i class="fas fa-utensils me-2"></i> Update Menu
                    </a>
                    <a asp-controller="Users" asp-action="Index" class="btn btn-light text-start border mb-2">
                        <i class="fas fa-users-cog me-2"></i> Staff Management
                    </a>
                    <a asp-controller="Reports" asp-action="Index" class="btn btn-light text-start border">
                        <i class="fas fa-chart-line me-2"></i> Business Reports
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
