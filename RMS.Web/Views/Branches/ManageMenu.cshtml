@model RMS.Web.Models.BranchMenuViewModel

@{
    ViewData["Title"] = "Manage Branch Menu";
}

<div class="mb-4">
    <h1 class="h3 mb-0 text-gray-800">Manage Menu for Branch: @Model.BranchName</h1>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Menu Items Availability</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" id="menuTable">
                <thead>
                    <tr>
                        <th>Menu Item</th>
                        <th>Category</th>
                        <th>Global Status</th>
                        <th>Branch Availability</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.MenuItems)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.CategoryName</td>
                            <td>
                                @if (item.IsAvailableGlobal)
                                {
                                    <span class="badge bg-soft-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-soft-danger">Unavailable</span>
                                }
                            </td>
                            <td>
                                <div class="form-check form-switch">
                                    <input class="form-check-input toggle-availability" type="checkbox" 
                                           data-menuitem-id="@item.MenuItemId" 
                                           @(item.IsAvailableInBranch ? "checked" : "")>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.toggle-availability').change(function () {
                var menuItemId = $(this).data('menuitem-id');
                var branchId = @Model.BranchId;
                var isAvailable = $(this).is(':checked');

                $.ajax({
                    url: '@Url.Action("ToggleMenuItemAvailability", "Branches")',
                    type: 'POST',
                    data: {
                        branchId: branchId,
                        menuItemId: menuItemId,
                        isAvailable: isAvailable
                    },
                    success: function (response) {
                        if (response.success) {
                            console.log('Availability updated successfully');
                        } else {
                            alert('Failed to update availability');
                        }
                    },
                    error: function () {
                        alert('Error updating availability');
                    }
                });
            });
        });
    </script>
}
