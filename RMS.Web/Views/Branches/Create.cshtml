@model RMS.Web.Models.Branch

@{
    ViewData["Title"] = "Create Branch";
}

<div class="mb-4">
    <h1 class="h3 mb-0 text-gray-800">Add New Branch</h1>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Branch Details</h6>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label font-weight-bold"></label>
                        <input asp-for="Name" class="form-control" placeholder="Enter branch name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsOpen">
                            <label class="form-check-label font-weight-bold" asp-for="IsOpen">Currently Open</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="WorkingHours" class="form-label font-weight-bold"></label>
                        <textarea asp-for="WorkingHours" class="form-control" rows="3" placeholder="e.g. Mon-Fri: 9AM-10PM"></textarea>
                        <span asp-validation-for="WorkingHours" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DeliveryZones" class="form-label font-weight-bold"></label>
                        <textarea asp-for="DeliveryZones" class="form-control" rows="3" placeholder="Enter delivery zones separated by commas"></textarea>
                        <span asp-validation-for="DeliveryZones" class="text-danger"></span>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Create Branch</button>
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
