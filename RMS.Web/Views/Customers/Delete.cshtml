@model RMS.Web.Models.Customer

@{
    ViewData["Title"] = "Delete Customer";
}

<div class="mb-4">
    <h1 class="h3 mb-0 text-gray-800">Delete Customer</h1>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-danger">Are you sure you want to delete this customer?</h6>
    </div>
    <div class="card-body">
        <p>Deleting this customer will also affect their order history records.</p>
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@Model.Name</dd>
            <dt class="col-sm-2">Phone</dt>
            <dd class="col-sm-10">@Model.Phone</dd>
        </dl>
        
        <form asp-action="Delete">
            <input type="hidden" asp-for="ID" />
            <button type="submit" class="btn btn-danger">Delete Permanently</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
