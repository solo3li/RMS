@model IEnumerable<RMS.Web.Models.CustomerIndexViewModel>

@{
    ViewData["Title"] = "Customers";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Customers</h1>
    <div class="d-flex gap-2">
        <a asp-action="ExportToCsv" class="btn btn-sm btn-outline-secondary shadow-sm">
            <i class="fas fa-file-export fa-sm text-secondary-50"></i> Export to CSV
        </a>
        <a asp-action="Create" class="btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Add New Customer
        </a>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">All Customers</h6>
        <form asp-action="Index" method="get" class="form-inline ml-auto">
            <div class="input-group input-group-sm">
                <input type="text" name="searchString" class="form-control bg-light border-0 small" placeholder="Search by name or phone..." value="@ViewData["CurrentFilter"]">
                <div class="input-group-append">
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-search fa-sm"></i>
                    </button>
                </div>
            </div>
        </form>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Total Orders</th>
                        <th>Total Spend</th>
                        <th>Tags</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Name</strong>
                            </td>
                            <td>@item.Phone</td>
                            <td>@item.TotalOrders</td>
                            <td>@item.TotalSpend.ToString("C")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Tags))
                                {
                                    foreach (var tag in item.Tags.Split(','))
                                    {
                                        <span class="badge bg-soft-info text-info me-1">@tag.Trim()</span>
                                    }
                                }
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-info" title="Details">
                                        <i class="fas fa-info-circle"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
